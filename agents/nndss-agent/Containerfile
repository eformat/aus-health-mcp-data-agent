FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN mkdir -p /app/.files /app/.chainlit && \
    chmod -R 777 /app/.files /app/.chainlit /app

USER 1001
EXPOSE 8080

CMD ["chainlit", "run", "app.py", "--port", "8080", "--host", "0.0.0.0", "--headless"]
