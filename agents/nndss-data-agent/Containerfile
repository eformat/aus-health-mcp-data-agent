# NNDSS Data Agent — Container Image
#
# Multi-stage build. Code, tools, prompts, skills, rules baked in.
# Only env-specific config injected at deploy time via ConfigMap/Secrets.

# Stage 1: Builder
FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

COPY pyproject.toml .
COPY src/ src/
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir .

# Stage 2: Runtime
FROM python:3.12-slim AS runtime

LABEL io.opencontainers.image.title="nndss-data-agent" \
      io.opencontainers.image.version="1.0.0" \
      io.opencontainers.image.description="Australian disease surveillance data agent with structured reasoning (NNDSS)"

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

COPY src/       src/
COPY tools/     tools/
COPY prompts/   prompts/
COPY skills/    skills/
COPY rules/     rules/
COPY agent.yaml agent.yaml
COPY AGENTS.md  ./

USER 1001
EXPOSE 8080

CMD ["python", "-m", "src.agent"]
